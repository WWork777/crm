generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  password     String
  name         String?
  activeTeamId String?
  teams        TeamMember[]
  tasks        Task[] // Задачи, где пользователь — исполнитель
}

model Team {
  id           String           @id @default(cuid())
  name         String
  createdAt    DateTime         @default(now())
  invitations  TeamInvitation[]
  members      TeamMember[]
  transactions Transaction[]
  tasks        Task[]
  boardColumns BoardColumn[]
  // ДОБАВЛЕНО: обратная связь для контрагентов
  counterparties Counterparty[] 
}

model TeamMember {
  id     String @id @default(cuid())
  role   String @default("MEMBER")
  userId String
  user   User   @relation(fields: [userId], references: [id])
  teamId String
  team   Team   @relation(fields: [teamId], references: [id])

  @@unique([userId, teamId])
}

model Transaction {
  id           String   @id @default(cuid())
  amount       Float
  type         String
  category     String?
  counterparty String?
  description  String?
  date         DateTime @default(now())
  status       String   @default("paid")
  teamId       String
  team         Team     @relation(fields: [teamId], references: [id])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("TODO")
  priority    Priority  @default(MEDIUM)
  createdAt   DateTime  @default(now())
  dueDate     DateTime?
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id])
  assigneeId  String?
  assignee    User?     @relation(fields: [assigneeId], references: [id])
}

model TeamInvitation {
  id        String   @id @default(cuid())
  email     String
  role      String   @default("MEMBER")
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id])

  @@unique([email, teamId])
}

model BoardColumn {
  id      String @id @default(cuid())
  title   String
  order   Int    @default(0)
  teamId  String
  team    Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Counterparty {
  id        String     @id @default(cuid())
  teamId    String
  name      String
  // ИСПРАВЛЕНО: SQLite не поддерживает Json, используем String
  fields    String?    
  contracts Contract[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  team      Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Contract {
  id             String       @id @default(cuid())
  counterpartyId String
  title          String
  fileUrl        String?
  date           DateTime?
  counterparty   Counterparty @relation(fields: [counterpartyId], references: [id], onDelete: Cascade)
}

model Lead {
  id          String   @id @default(uuid())
  title       String   // Название сделки
  contactName String?  // Имя клиента
  phone       String?
  email       String?
  value       Float    @default(0) // Сумма сделки
  statusId    String   // ID колонки (стадии)
  priority    String   @default("MEDIUM")
  teamId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  paymentType String   @default("FIXED")
  status      LeadStatus @relation(fields: [statusId], references: [id])
}

model LeadStatus {
  id      String @id @default(uuid())
  title   String
  order   Int
  teamId  String
  color   String? @default("indigo")
  leads   Lead[]
}